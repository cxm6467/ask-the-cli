# ask-the-cli Configuration Example
# Copy this file to .env or add these exports to your .zshrc

# ============================================
# PROVIDER SELECTION (choose one)
# ============================================

# Option 1: Ollama (Local, Free, Private)
# Setup: https://ollama.com/download
#   1. Install: brew install ollama (or curl -fsSL https://ollama.com/install.sh | sh)
#   2. Start: ollama serve
#   3. Pull model: ollama pull llama3.2
export ASK_THE_CLI_PROVIDER="ollama"
export ASK_THE_CLI_MODEL="llama3.2"  # or mistral, llama3.1, etc.
# export ASK_THE_CLI_OLLAMA_HOST="http://localhost:11434"  # custom host

# Option 2: Anthropic Claude (Paid API)
# Get API key: https://console.anthropic.com/
# export ASK_THE_CLI_PROVIDER="anthropic"
# export ASK_THE_CLI_API_KEY="sk-ant-api03-..."
# export ASK_THE_CLI_MODEL="claude-3-5-sonnet-20241022"

# Option 3: OpenAI GPT (Paid API)
# Get API key: https://platform.openai.com/
# export ASK_THE_CLI_PROVIDER="openai"
# export ASK_THE_CLI_API_KEY="sk-..."
# export ASK_THE_CLI_MODEL="gpt-4o-mini"  # or gpt-4o, gpt-4-turbo

# ============================================
# ADVANCED SETTINGS (optional)
# ============================================

# Maximum tokens in response (default: 1024)
# export ASK_THE_CLI_MAX_TOKENS=2048

# Custom API URL (advanced - usually auto-set based on provider)
# export ASK_THE_CLI_API_URL="https://custom-endpoint.com"

# ============================================
# ANIMATION & DISPLAY SETTINGS (optional)
# ============================================

# Enable animated typewriter effect (default: true)
export ASK_THE_CLI_ANIMATE=true

# Animation speed - delay between characters in seconds (default: 0.01)
# Lower = faster, Higher = slower
# export ASK_THE_CLI_ANIMATION_DELAY=0.01

# Text color for output (default: cyan)
# Options: black, red, green, yellow, blue, magenta, cyan, white, default
export ASK_THE_CLI_TEXT_COLOR="cyan"

# Tip: Press ESC while text is animating to skip to the end instantly!
